# ==============================================================================
# AgentForge — Global Environment Variables
# ==============================================================================
# Copy this file to .env and fill in your values.
# This file contains ALL keys used across departments.
# Department-specific .env.example files show which keys each department needs.
# ==============================================================================

# --- LLM Providers ---
GROQ_API_KEY=
OPENROUTER_API_KEY=
GOOGLE_AI_KEY=
GEMINI_API_KEY=

# --- Supabase ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Notion ---
NOTION_API_KEY=

# --- Discord ---
DISCORD_BOT_TOKEN=
DISCORD_ALERTS_CHANNEL_ID=

# --- Resend (Email) ---
RESEND_API_KEY=

# --- GitHub ---
GITHUB_TOKEN=

# --- Vercel ---
VERCEL_TOKEN=

# --- Railway ---
RAILWAY_TOKEN=
RAILWAY_PROJECT_ID=
RAILWAY_ENVIRONMENT_ID=

# --- Cloudflare ---
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# --- SSH / VPS ---
SSH_HOST=
SSH_USER=
SSH_KEY_PATH=~/.ssh/id_ed25519
SSH_PORT=22

# --- HubSpot CRM ---
HUBSPOT_API_KEY=
HUBSPOT_PORTAL_ID=

# --- Slack ---
SLACK_BOT_TOKEN=
SLACK_APP_ID=
SLACK_SIGNING_SECRET=

# --- Google Workspace ---
GOOGLE_WORKSPACE_SERVICE_ACCOUNT_JSON=
GOOGLE_WORKSPACE_DELEGATED_EMAIL=

# --- Asana / Linear ---
ASANA_PERSONAL_ACCESS_TOKEN=
LINEAR_API_KEY=

# --- Stripe / Xero ---
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=

# --- Application ---
ENVIRONMENT=development
LOG_LEVEL=INFO
PORT=8000
